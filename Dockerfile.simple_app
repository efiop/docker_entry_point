FROM rust:1.91-slim-bookworm AS build

WORKDIR /src
COPY simple_app.rs /src/simple_app.rs
RUN rustc -O /src/simple_app.rs -o /src/simple_app

FROM debian:bookworm-slim

RUN ! command -v python && ! command -v python3
WORKDIR /app
COPY --from=build /src/simple_app /app/simple_app

EXPOSE 8000
ENTRYPOINT ["/app/simple_app"]
CMD ["--host", "0.0.0.0", "--port", "8000"]
